---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Tools" description="Interactive chemistry calculators and tools">
  <style>
    h1 { font-size: 28px; font-weight: 600; color: #26215C; margin-bottom: 8px; }
    .subtitle { font-size: 16px; color: #888; margin-bottom: 2rem; }
    .coming-soon { background: #FBEAF0; border-radius: 12px; padding: 2rem; text-align: center; color: #72243E; }
  </style>
  <h1>Chemistry Tools</h1>
  <p class="subtitle">Calculators, converters, and interactive tools</p>
  <div class="coming-soon">Tools coming soon — molar mass calculator, equation balancer, and more!</div>
</Layout>