---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Molar Mass Calculator" description="Calculate the molar mass of any chemical formula instantly">
  <style>
    .page-header { background: #3C3489; border-radius: 12px; padding: 2rem; margin-bottom: 2rem; }
    .page-title { font-size: 28px; font-weight: 600; color: #EEEDFE; margin-bottom: 8px; }
    .page-desc { font-size: 15px; color: #AFA9EC; line-height: 1.6; }
    .calculator { background: white; border-radius: 12px; border: 0.5px solid #e0e0e0; padding: 2rem; margin-bottom: 2rem; }
    .input-label { font-size: 13px; font-weight: 600; color: #26215C; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
    .input-row { display: flex; gap: 12px; margin-bottom: 1rem; }
    .formula-input { flex: 1; padding: 12px 16px; font-size: 18px; border: 2px solid #EEEDFE; border-radius: 8px; outline: none; font-family: monospace; }
    .formula-input:focus { border-color: #534AB7; }
    .calc-btn { background: #534AB7; color: white; border: none; padding: 12px 24px; border-radius: 8px; font-size: 16px; cursor: pointer; font-family: inherit; }
    .calc-btn:hover { background: #3C3489; }
    .result-box { background: #EEEDFE; border-radius: 8px; padding: 1.5rem; margin-top: 1rem; display: none; }
    .result-box.visible { display: block; }
    .result-label { font-size: 13px; color: #534AB7; font-weight: 600; margin-bottom: 6px; }
    .result-value { font-size: 36px; font-weight: 600; color: #26215C; }
    .result-unit { font-size: 16px; color: #534AB7; margin-left: 4px; }
    .result-breakdown { margin-top: 1rem; font-size: 14px; color: #534AB7; line-height: 1.8; }
    .error-box { background: #FAECE7; border-radius: 8px; padding: 1rem; margin-top: 1rem; color: #712B13; font-size: 14px; display: none; }
    .error-box.visible { display: block; }
    .examples { background: #f5f5f5; border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; }
    .examples-title { font-size: 13px; font-weight: 600; color: #26215C; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 12px; }
    .example-pills { display: flex; flex-wrap: wrap; gap: 8px; }
    .example-pill { background: white; border: 0.5px solid #CECBF6; color: #534AB7; font-size: 14px; padding: 6px 14px; border-radius: 999px; cursor: pointer; font-family: monospace; }
    .example-pill:hover { background: #EEEDFE; }
    .how-it-works { background: #f5f5f5; border-radius: 12px; padding: 1.5rem; }
    .how-title { font-size: 13px; font-weight: 600; color: #26215C; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 12px; }
    .how-text { font-size: 14px; color: #555; line-height: 1.7; }
    .how-text strong { color: #26215C; }
  </style>

  <div class="page-header">
    <h1 class="page-title">Molar Mass Calculator</h1>
    <p class="page-desc">Enter a chemical formula to instantly calculate its molar mass in grams per mole.</p>
  </div>

  <div class="calculator">
    <div class="input-label">Chemical formula</div>
    <div class="input-row">
      <input type="text" class="formula-input" id="formula" placeholder="e.g. H2O, NaCl, C6H12O6" />
      <button class="calc-btn" onclick="calculate()">Calculate</button>
    </div>
    <div class="error-box" id="error"></div>
    <div class="result-box" id="result">
      <div class="result-label">Molar mass</div>
      <div><span class="result-value" id="result-value"></span><span class="result-unit">g/mol</span></div>
      <div class="result-breakdown" id="result-breakdown"></div>
    </div>
  </div>

  <div class="examples">
    <div class="examples-title">Try these examples</div>
    <div class="example-pills">
      <span class="example-pill" onclick="setFormula('H2O')">H2O</span>
      <span class="example-pill" onclick="setFormula('NaCl')">NaCl</span>
      <span class="example-pill" onclick="setFormula('CO2')">CO2</span>
      <span class="example-pill" onclick="setFormula('C6H12O6')">C6H12O6</span>
      <span class="example-pill" onclick="setFormula('H2SO4')">H2SO4</span>
      <span class="example-pill" onclick="setFormula('CaCO3')">CaCO3</span>
      <span class="example-pill" onclick="setFormula('NH3')">NH3</span>
      <span class="example-pill" onclick="setFormula('Fe2O3')">Fe2O3</span>
      <span class="example-pill" onclick="setFormula('C12H22O11')">C12H22O11</span>
      <span class="example-pill" onclick="setFormula('KMnO4')">KMnO4</span>
    </div>
  </div>

  <div class="how-it-works">
    <div class="how-title">How molar mass works</div>
    <div class="how-text">
      The <strong>molar mass</strong> of a compound is the mass of one mole of that substance in grams. One mole contains 6.022 × 10²³ particles (Avogadro's number). To calculate molar mass, add up the atomic masses of all atoms in the formula. For example, water (H₂O) has 2 hydrogen atoms (2 × 1.008 = 2.016) plus 1 oxygen atom (15.999) giving a molar mass of <strong>18.015 g/mol</strong>.
    </div>
  </div>

  <script>
    const elements = {
      H:1.008,He:4.003,Li:6.941,Be:9.012,B:10.811,C:12.011,N:14.007,O:15.999,
      F:18.998,Ne:20.180,Na:22.990,Mg:24.305,Al:26.982,Si:28.086,P:30.974,S:32.065,
      Cl:35.453,Ar:39.948,K:39.098,Ca:40.078,Sc:44.956,Ti:47.867,V:50.942,Cr:51.996,
      Mn:54.938,Fe:55.845,Co:58.933,Ni:58.693,Cu:63.546,Zn:65.38,Ga:69.723,Ge:72.630,
      As:74.922,Se:78.971,Br:79.904,Kr:83.798,Rb:85.468,Sr:87.62,Y:88.906,Zr:91.224,
      Nb:92.906,Mo:95.96,Tc:98,Ru:101.07,Rh:102.906,Pd:106.42,Ag:107.868,Cd:112.411,
      In:114.818,Sn:118.710,Sb:121.760,Te:127.60,I:126.904,Xe:131.293,Cs:132.905,
      Ba:137.327,La:138.905,Ce:140.116,Pr:140.908,Nd:144.242,Pm:145,Sm:150.36,
      Eu:151.964,Gd:157.25,Tb:158.925,Dy:162.500,Ho:164.930,Er:167.259,Tm:168.934,
      Yb:173.054,Lu:174.967,Hf:178.49,Ta:180.948,W:183.84,Re:186.207,Os:190.23,
      Ir:192.217,Pt:195.084,Au:196.967,Hg:200.592,Tl:204.383,Pb:207.2,Bi:208.980,
      Po:209,At:210,Rn:222,Fr:223,Ra:226,Ac:227,Th:232.038,Pa:231.036,U:238.029
    };

    function parseFormula(formula) {
      const stack = [{}];
      let i = 0;
      while (i < formula.length) {
        if (formula[i] === '(') {
          stack.push({});
          i++;
        } else if (formula[i] === ')') {
          i++;
          let numStr = '';
          while (i < formula.length && /\d/.test(formula[i])) {
            numStr += formula[i++];
          }
          const num = parseInt(numStr) || 1;
          const top = stack.pop();
          for (const el in top) {
            stack[stack.length-1][el] = (stack[stack.length-1][el] || 0) + top[el] * num;
          }
        } else if (/[A-Z]/.test(formula[i])) {
          let symbol = formula[i++];
          while (i < formula.length && /[a-z]/.test(formula[i])) {
            symbol += formula[i++];
          }
          let numStr = '';
          while (i < formula.length && /\d/.test(formula[i])) {
            numStr += formula[i++];
          }
          const num = parseInt(numStr) || 1;
          stack[stack.length-1][symbol] = (stack[stack.length-1][symbol] || 0) + num;
        } else {
          i++;
        }
      }
      return stack[0];
    }

    function calculate() {
      const formula = document.getElementById('formula').value.trim();
      const resultBox = document.getElementById('result');
      const errorBox = document.getElementById('error');
      resultBox.classList.remove('visible');
      errorBox.classList.remove('visible');
      if (!formula) return;
      try {
        const parsed = parseFormula(formula);
        let total = 0;
        let breakdown = [];
        for (const el in parsed) {
          if (!elements[el]) {
            errorBox.textContent = `Unknown element: ${el}. Please check your formula.`;
            errorBox.classList.add('visible');
            return;
          }
          const mass = elements[el] * parsed[el];
          total += mass;
          breakdown.push(`${el}: ${parsed[el]} × ${elements[el]} = ${mass.toFixed(3)}`);
        }
        document.getElementById('result-value').textContent = total.toFixed(3);
        document.getElementById('result-breakdown').innerHTML = breakdown.join('<br>');
        resultBox.classList.add('visible');
      } catch(e) {
        errorBox.textContent = 'Invalid formula. Please check your input.';
        errorBox.classList.add('visible');
      }
    }

    function setFormula(formula) {
      document.getElementById('formula').value = formula;
      calculate();
    }

    document.getElementById('formula').addEventListener('keypress', function(e) {
      if (e.key === 'Enter') calculate();
    });
  </script>
</Layout>
