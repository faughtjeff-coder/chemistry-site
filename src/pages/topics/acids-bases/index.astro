---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="Acids and Bases" description="Chemistry articles about acids and bases for all levels">
  <style>
    .page-header { background: #712B13; border-radius: 12px; padding: 2rem; margin-bottom: 2rem; }
    .page-title { font-size: 28px; font-weight: 600; color: #FAECE7; margin-bottom: 8px; }
    .page-desc { font-size: 15px; color: #F5C4B3; line-height: 1.6; }
    .coming-soon { background: #FAECE7; border-radius: 12px; padding: 2rem; text-align: center; color: #712B13; font-size: 15px; }
    .level-info { display: flex; gap: 8px; margin-top: 12px; flex-wrap: wrap; }
    .level-tag { font-size: 12px; padding: 4px 12px; border-radius: 999px; }
  </style>
  <div class="page-header">
    <h1 class="page-title">Acids & Bases</h1>
    <p class="page-desc">pH, neutralization, buffers — understanding the chemistry of acids and bases from lemon juice to stomach acid.</p>
    <div class="level-info">
      <span class="level-tag" style="background:#FAEEDA;color:#633806;">Beginner</span>
      <span class="level-tag" style="background:#E1F5EE;color:#085041;">General</span>
      <span class="level-tag" style="background:#E6F1FB;color:#0C447C;">AP</span>
    </div>
  </div>
  <div class="coming-soon">Acids & bases articles coming soon — check back next week!</div>
</Layout>