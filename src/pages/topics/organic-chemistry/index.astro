---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="Organic Chemistry" description="Chemistry articles about organic chemistry for all levels">
  <style>
    .page-header { background: #72243E; border-radius: 12px; padding: 2rem; margin-bottom: 2rem; }
    .page-title { font-size: 28px; font-weight: 600; color: #FBEAF0; margin-bottom: 8px; }
    .page-desc { font-size: 15px; color: #F4C0D1; line-height: 1.6; }
    .coming-soon { background: #FBEAF0; border-radius: 12px; padding: 2rem; text-align: center; color: #72243E; font-size: 15px; }
    .level-info { display: flex; gap: 8px; margin-top: 12px; flex-wrap: wrap; }
    .level-tag { font-size: 12px; padding: 4px 12px; border-radius: 999px; }
  </style>
  <div class="page-header">
    <h1 class="page-title">Organic Chemistry</h1>
    <p class="page-desc">Carbon chains, functional groups, polymers — the chemistry of life and the molecules that make up everything living.</p>
    <div class="level-info">
      <span class="level-tag" style="background:#FAEEDA;color:#633806;">Beginner</span>
      <span class="level-tag" style="background:#E1F5EE;color:#085041;">General</span>
      <span class="level-tag" style="background:#E6F1FB;color:#0C447C;">AP</span>
    </div>
  </div>
  <div class="coming-soon">Organic chemistry articles coming soon — check back next week!</div>
</Layout>