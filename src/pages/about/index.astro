---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="About" description="About ChemSpark">
  <style>
    h1 { font-size: 28px; font-weight: 600; color: #26215C; margin-bottom: 8px; }
    .subtitle { font-size: 16px; color: #888; margin-bottom: 2rem; }
    .about-box { background: #EEEDFE; border-radius: 12px; padding: 2rem; color: #26215C; line-height: 1.8; font-size: 15px; }
  </style>
  <h1>About ChemSpark</h1>
  <p class="subtitle">Chemistry for every level</p>
  <div class="about-box">
    ChemSpark is a free chemistry resource for high school students at every level — from complete beginners to AP Chemistry. Each week a new reaction article is published with videos, clear explanations, and links to real research. Our goal is to make chemistry engaging, visual, and accessible to everyone.
  </div>
</Layout>