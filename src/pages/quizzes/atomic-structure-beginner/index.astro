---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="Atomic Structure Quiz — Beginner" description="Test your knowledge of atomic structure with this beginner level quiz">
  <style>
    .quiz-header { background: #26215C; border-radius: 12px; padding: 2rem; margin-bottom: 2rem; }
    .quiz-title { font-size: 26px; font-weight: 600; color: #EEEDFE; margin-bottom: 8px; }
    .quiz-meta { font-size: 14px; color: #AFA9EC; }
    .question-box { background: white; border-radius: 12px; border: 0.5px solid #e0e0e0; padding: 2rem; margin-bottom: 1.5rem; display: none; }
    .question-box.active { display: block; }
    .question-number { font-size: 12px; font-weight: 600; color: #888; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
    .question-text { font-size: 18px; font-weight: 500; color: #1a1a2e; margin-bottom: 1.5rem; line-height: 1.5; }
    .options { display: flex; flex-direction: column; gap: 10px; }
    .option { background: #f5f5f5; border: 2px solid transparent; border-radius: 8px; padding: 12px 16px; font-size: 15px; color: #1a1a2e; cursor: pointer; text-align: left; font-family: inherit; }
    .option:hover:not(:disabled) { border-color: #AFA9EC; }
    .option.correct { background: #E1F5EE; border-color: #085041; color: #085041; }
    .option.wrong { background: #FAECE7; border-color: #712B13; color: #712B13; }
    .option.reveal { background: #E1F5EE; border-color: #085041; color: #085041; }
    .feedback { margin-top: 1rem; padding: 0.75rem 1rem; border-radius: 8px; font-size: 14px; display: none; line-height: 1.5; }
    .feedback.show { display: block; }
    .feedback.correct { background: #E1F5EE; color: #085041; }
    .feedback.wrong { background: #FAECE7; color: #712B13; }
    .next-btn { margin-top: 1rem; background: #534AB7; color: white; border: none; padding: 10px 24px; border-radius: 8px; font-size: 15px; cursor: pointer; font-family: inherit; display: none; }
    .next-btn.show { display: block; }
    .progress { background: #f5f5f5; border-radius: 999px; height: 8px; margin-bottom: 2rem; overflow: hidden; }
    .progress-bar { background: #534AB7; height: 100%; border-radius: 999px; transition: width 0.3s; }
    .score-box { background: #26215C; border-radius: 12px; padding: 2rem; text-align: center; display: none; }
    .score-box.show { display: block; }
    .score-title { font-size: 22px; font-weight: 600; color: #EEEDFE; margin-bottom: 8px; }
    .score-value { font-size: 48px; font-weight: 600; color: #FAC775; margin-bottom: 8px; }
    .score-message { font-size: 15px; color: #AFA9EC; margin-bottom: 1.5rem; }
    .retry-btn { background: #534AB7; color: white; border: none; padding: 10px 24px; border-radius: 8px; font-size: 15px; cursor: pointer; font-family: inherit; }
  </style>

  <div class="quiz-header">
    <h1 class="quiz-title">Atomic Structure — Beginner</h1>
    <div class="quiz-meta">10 questions · Multiple choice · Instant feedback</div>
  </div>

  <div class="progress">
    <div class="progress-bar" id="progress-bar" style="width:0%"></div>
  </div>

  <div id="quiz-container"></div>
  <div class="score-box" id="score-box">
    <div class="score-title">Quiz complete!</div>
    <div class="score-value" id="score-value"></div>
    <div class="score-message" id="score-message"></div>
    <button class="retry-btn" id="retry-btn">Try again</button>
  </div>

  <script>
    const questions = [
      {
        text: "What is an atom?",
        options: [
          "A molecule made of two or more elements",
          "The smallest particle of an element that keeps its chemical properties",
          "A charged particle found in the nucleus",
          "A type of chemical bond"
        ],
        correct: 1,
        feedback: {
          correct: "Correct! An atom is the smallest particle of an element that keeps its chemical properties.",
          wrong: "Not quite. An atom is the smallest particle of an element that keeps its chemical properties."
        }
      },
      {
        text: "Where are protons found in an atom?",
        options: ["In the electron shells", "Orbiting the nucleus", "In the nucleus", "Between atoms"],
        correct: 2,
        feedback: {
          correct: "Correct! Protons are found in the nucleus at the center of the atom.",
          wrong: "Not quite. Protons are found in the nucleus, not in the electron shells."
        }
      },
      {
        text: "What charge does an electron have?",
        options: ["Positive", "No charge", "Negative", "It depends on the element"],
        correct: 2,
        feedback: {
          correct: "Correct! Electrons have a negative charge.",
          wrong: "Not quite. Electrons have a negative charge. Protons are positive and neutrons have no charge."
        }
      },
      {
        text: "What is the atomic number of an element?",
        options: [
          "The total number of protons and neutrons",
          "The number of protons in the nucleus",
          "The number of electrons in the outer shell",
          "The mass of one atom in grams"
        ],
        correct: 1,
        feedback: {
          correct: "Correct! The atomic number is the number of protons in the nucleus.",
          wrong: "Not quite. The atomic number is the number of protons. The mass number is protons plus neutrons."
        }
      },
      {
        text: "In a neutral atom, how does the number of protons compare to electrons?",
        options: [
          "There are always more protons than electrons",
          "There are always more electrons than protons",
          "They are equal",
          "Protons and electrons are not related"
        ],
        correct: 2,
        feedback: {
          correct: "Correct! In a neutral atom the number of protons equals the number of electrons.",
          wrong: "Not quite. In a neutral atom the positive charges (protons) and negative charges (electrons) must balance — so they are equal."
        }
      },
      {
        text: "What particle has no electrical charge?",
        options: ["Proton", "Neutron", "Electron", "Ion"],
        correct: 1,
        feedback: {
          correct: "Correct! Neutrons have no electrical charge.",
          wrong: "Not quite. Neutrons have no charge. Protons are positive and electrons are negative."
        }
      },
      {
        text: "Carbon has an atomic number of 6. How many protons does a carbon atom have?",
        options: ["12", "3", "6", "8"],
        correct: 2,
        feedback: {
          correct: "Correct! The atomic number is 6 so carbon has 6 protons.",
          wrong: "Not quite. The atomic number tells you the number of protons. Carbon has atomic number 6 so it has 6 protons."
        }
      },
      {
        text: "Where are electrons found in an atom?",
        options: [
          "Inside the nucleus",
          "In shells around the nucleus",
          "Between the protons and neutrons",
          "Only on the surface of the atom"
        ],
        correct: 1,
        feedback: {
          correct: "Correct! Electrons are found in shells around the nucleus.",
          wrong: "Not quite. Electrons orbit the nucleus in shells — they are not inside the nucleus."
        }
      },
      {
        text: "What is the maximum number of electrons in the first electron shell?",
        options: ["8", "2", "18", "4"],
        correct: 1,
        feedback: {
          correct: "Correct! The first electron shell holds a maximum of 2 electrons.",
          wrong: "Not quite. The first shell holds a maximum of 2 electrons. The second shell holds up to 8."
        }
      },
      {
        text: "What happens to an atom if it gains or loses electrons?",
        options: [
          "It becomes a different element",
          "It explodes",
          "Nothing changes",
          "It becomes a charged ion"
        ],
        correct: 3,
        feedback: {
          correct: "Correct! When an atom gains or loses electrons it becomes a charged ion.",
          wrong: "Not quite. When an atom gains or loses electrons it becomes an ion — a charged particle."
        }
      }
    ];

    let score = 0;
    let current = 0;
    let answered = false;

    function buildQuestion(index) {
      const q = questions[index];
      const div = document.createElement('div');
      div.className = 'question-box active';
      div.id = 'question-box';
      div.innerHTML = `
        <div class="question-number">Question ${index + 1} of ${questions.length}</div>
        <div class="question-text">${q.text}</div>
        <div class="options" id="options-box">
          ${q.options.map((opt, i) => `<button class="option" data-index="${i}">${opt}</button>`).join('')}
        </div>
        <div class="feedback" id="feedback-box"></div>
        <button class="next-btn" id="next-btn">${index === questions.length - 1 ? 'See my score →' : 'Next question →'}</button>
      `;
      return div;
    }

    function showQuestion(index) {
      answered = false;
      const container = document.getElementById('quiz-container');
      container.innerHTML = '';
      const qDiv = buildQuestion(index);
      container.appendChild(qDiv);
      document.getElementById('options-box').querySelectorAll('.option').forEach(btn => {
        btn.addEventListener('click', function() {
          if (answered) return;
          answered = true;
          const chosen = parseInt(this.dataset.index);
          const correct = questions[index].correct;
          const allOptions = document.getElementById('options-box').querySelectorAll('.option');
          allOptions.forEach(b => b.disabled = true);
          const fb = document.getElementById('feedback-box');
          if (chosen === correct) {
            this.classList.add('correct');
            fb.textContent = questions[index].feedback.correct;
            fb.className = 'feedback show correct';
            score++;
          } else {
            this.classList.add('wrong');
            allOptions[correct].classList.add('reveal');
            fb.textContent = questions[index].feedback.wrong;
            fb.className = 'feedback show wrong';
          }
          document.getElementById('next-btn').classList.add('show');
          document.getElementById('progress-bar').style.width = ((index + 1) / questions.length * 100) + '%';
        });
      });
      document.getElementById('next-btn').addEventListener('click', function() {
        if (index === questions.length - 1) {
          showScore();
        } else {
          current++;
          showQuestion(current);
        }
      });
    }

    function showScore() {
      document.getElementById('quiz-container').innerHTML = '';
      const scoreBox = document.getElementById('score-box');
      scoreBox.classList.add('show');
      document.getElementById('score-value').textContent = score + '/' + questions.length;
      const pct = score / questions.length;
      let msg = '';
      if (pct === 1) msg = 'Perfect score! Outstanding work.';
      else if (pct >= 0.8) msg = 'Excellent! You really know your atoms.';
      else if (pct >= 0.6) msg = 'Good work! Review a couple of topics to improve.';
      else if (pct >= 0.4) msg = 'Keep going! Read the atomic structure article and try again.';
      else msg = 'Don\'t give up! Read the atomic structure article carefully and retry.';
      document.getElementById('score-message').textContent = msg;
    }

    document.getElementById('retry-btn').addEventListener('click', function() {
      score = 0;
      current = 0;
      document.getElementById('score-box').classList.remove('show');
      document.getElementById('progress-bar').style.width = '0%';
      showQuestion(0);
    });

    showQuestion(0);
  </script>
</Layout>
