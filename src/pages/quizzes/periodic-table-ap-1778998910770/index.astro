---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="AP Chemistry: Periodic Table Mastery Quiz" description="Test your advanced knowledge of periodic trends, electron configurations, and chemical properties">
  <style>
    .quiz-header { background: #26215C; border-radius: 12px; padding: 2rem; margin-bottom: 2rem; }
    .quiz-title { font-size: 26px; font-weight: 600; color: #EEEDFE; margin-bottom: 8px; }
    .quiz-meta { font-size: 14px; color: #AFA9EC; }
    .question-box { background: white; border-radius: 12px; border: 0.5px solid #e0e0e0; padding: 2rem; margin-bottom: 1.5rem; display: none; }
    .question-box.active { display: block; }
    .question-number { font-size: 12px; font-weight: 600; color: #888; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
    .question-text { font-size: 18px; font-weight: 500; color: #1a1a2e; margin-bottom: 1.5rem; line-height: 1.5; }
    .options { display: flex; flex-direction: column; gap: 10px; }
    .option { background: #f5f5f5; border: 2px solid transparent; border-radius: 8px; padding: 12px 16px; font-size: 15px; color: #1a1a2e; cursor: pointer; text-align: left; font-family: inherit; }
    .option:hover:not(:disabled) { border-color: #AFA9EC; }
    .option.correct { background: #E1F5EE; border-color: #085041; color: #085041; }
    .option.wrong { background: #FAECE7; border-color: #712B13; color: #712B13; }
    .option.reveal { background: #E1F5EE; border-color: #085041; color: #085041; }
    .feedback { margin-top: 1rem; padding: 0.75rem 1rem; border-radius: 8px; font-size: 14px; display: none; line-height: 1.5; }
    .feedback.show { display: block; }
    .feedback.correct { background: #E1F5EE; color: #085041; }
    .feedback.wrong { background: #FAECE7; color: #712B13; }
    .next-btn { margin-top: 1rem; background: #534AB7; color: white; border: none; padding: 10px 24px; border-radius: 8px; font-size: 15px; cursor: pointer; font-family: inherit; display: none; }
    .next-btn.show { display: block; }
    .progress { background: #f5f5f5; border-radius: 999px; height: 8px; margin-bottom: 2rem; overflow: hidden; }
    .progress-bar { background: #534AB7; height: 100%; border-radius: 999px; transition: width 0.3s; }
    .score-box { background: #26215C; border-radius: 12px; padding: 2rem; text-align: center; display: none; }
    .score-box.show { display: block; }
    .score-title { font-size: 22px; font-weight: 600; color: #EEEDFE; margin-bottom: 8px; }
    .score-value { font-size: 48px; font-weight: 600; color: #FAC775; margin-bottom: 8px; }
    .score-message { font-size: 15px; color: #AFA9EC; margin-bottom: 1.5rem; }
    .retry-btn { background: #534AB7; color: white; border: none; padding: 10px 24px; border-radius: 8px; font-size: 15px; cursor: pointer; font-family: inherit; }
  </style>

  <div class="quiz-header">
    <h1 class="quiz-title">AP Chemistry: Periodic Table Mastery Quiz</h1>
    <div class="quiz-meta">5 questions · Multiple choice · Instant feedback</div>
  </div>

  <div class="progress"><div class="progress-bar" id="progress-bar" style="width:0%"></div></div>
  <div id="quiz-container"></div>
  <div class="score-box" id="score-box">
    <div class="score-title">Quiz complete!</div>
    <div class="score-value" id="score-value"></div>
    <div class="score-message" id="score-message"></div>
    <button class="retry-btn" id="retry-btn">Try again</button>
  </div>

  <script>
    const questions = [
      {
        text: "Which of the following electron configurations represents an element with the highest first ionization energy?",
        options: [
          "[Ne] 3s¹",
          "[Ne] 3s²",
          "[Ar] 4s¹",
          "[He] 2s² 2p⁶"
        ],
        correct: 3,
        feedback: {
          correct: "Correct! Neon ([He] 2s² 2p⁶) has a complete outer shell, making it extremely stable and requiring the most energy to remove an electron. Noble gases have the highest ionization energies in their periods.",
          wrong: "Incorrect. The element with electron configuration [He] 2s² 2p⁶ (neon) has the highest first ionization energy because it has a complete outer shell, making it very stable and difficult to ionize."
        }
      },
      {
        text: "Based on periodic trends, which element would have an atomic radius most similar to that of silicon (Si)?",
        options: [
          "Germanium (Ge)",
          "Aluminum (Al)",
          "Phosphorus (P)",
          "Carbon (C)"
        ],
        correct: 0,
        feedback: {
          correct: "Correct! Germanium is directly below silicon in Group 14. Elements in the same group have similar properties, and while Ge is larger due to additional electron shells, it has the most similar atomic radius among the choices.",
          wrong: "Incorrect. Germanium (Ge) would have the most similar atomic radius to silicon because they're in the same group (Group 14). Elements in the same group show similar trends in atomic size."
        }
      },
      {
        text: "The effective nuclear charge (Z_eff) experienced by a 3p electron in chlorine is approximately 6. This value is less than chlorine's actual nuclear charge (17) primarily because of:",
        options: [
          "The penetration ability of p orbitals",
          "Shielding by core electrons in the 1s, 2s, 2p, and 3s orbitals",
          "The large size of the 3p orbital",
          "Electron-electron repulsion in the 3p subshell"
        ],
        correct: 1,
        feedback: {
          correct: "Correct! The effective nuclear charge is reduced because inner shell electrons (1s², 2s², 2p⁶, 3s²) shield the 3p electrons from the full nuclear charge. These 10 core electrons significantly reduce the nuclear attraction felt by the 3p electrons.",
          wrong: "Incorrect. The primary reason Z_eff is less than the nuclear charge is shielding by core electrons. The 10 inner electrons (1s², 2s², 2p⁶, 3s²) shield the 3p electrons from the full +17 nuclear charge."
        }
      },
      {
        text: "Which of the following best explains why the second ionization energy of magnesium (738 kJ/mol) is much lower than the second ionization energy of sodium (4562 kJ/mol)?",
        options: [
          "Magnesium has a larger atomic radius than sodium",
          "Magnesium's second electron is removed from the same subshell (3s), while sodium's second electron is removed from a lower energy level (2p)",
          "Magnesium has a higher nuclear charge than sodium",
          "The electron-electron repulsion is greater in magnesium"
        ],
        correct: 1,
        feedback: {
          correct: "Correct! Mg's electron configuration is [Ne] 3s². Its second electron comes from the 3s orbital. Na's configuration is [Ne] 3s¹, so its second electron must come from the much more stable 2p orbital, requiring significantly more energy.",
          wrong: "Incorrect. The key difference is that Mg's second electron comes from the same 3s subshell, while Na's second electron must be removed from the lower energy 2p subshell, which is much more tightly bound to the nucleus."
        }
      },
      {
        text: "Consider the isoelectronic series: N³⁻, O²⁻, F⁻, Ne, Na⁺, Mg²⁺, Al³⁺. Which statement about their ionic/atomic radii is correct?",
        options: [
          "All have identical radii since they have the same electron configuration",
          "N³⁻ > O²⁻ > F⁻ > Ne > Na⁺ > Mg²⁺ > Al³⁺",
          "Al³⁺ > Mg²⁺ > Na⁺ > Ne > F⁻ > O²⁻ > N³⁻",
          "The neutral atom (Ne) has the largest radius in this series"
        ],
        correct: 1,
        feedback: {
          correct: "Correct! In an isoelectronic series, ionic radius decreases as nuclear charge increases. N³⁻ has the lowest nuclear charge (+7) attracting 10 electrons, while Al³⁺ has the highest (+13), creating the strongest attraction and smallest radius.",
          wrong: "Incorrect. In an isoelectronic series, radius decreases with increasing nuclear charge. N³⁻ (Z=7) is largest because it has the weakest nuclear attraction for the 10 electrons, while Al³⁺ (Z=13) is smallest due to strongest attraction."
        }
      }
    ];

    let score = 0;
    let current = 0;
    let answered = false;

    function buildQuestion(index) {
      const q = questions[index];
      const div = document.createElement('div');
      div.className = 'question-box active';
      div.id = 'question-box';
      div.innerHTML = `
        <div class="question-number">Question ${index + 1} of ${questions.length}</div>
        <div class="question-text">${q.text}</div>
        <div class="options" id="options-box">
          ${q.options.map((opt, i) => `<button class="option" data-index="${i}">${opt}</button>`).join('')}
        </div>
        <div class="feedback" id="feedback-box"></div>
        <button class="next-btn" id="next-btn">${index === questions.length - 1 ? 'See my score →' : 'Next question →'}</button>
      `;
      return div;
    }

    function showQuestion(index) {
      answered = false;
      const container = document.getElementById('quiz-container');
      container.innerHTML = '';
      const qDiv = buildQuestion(index);
      container.appendChild(qDiv);
      document.getElementById('options-box').querySelectorAll('.option').forEach(btn => {
        btn.addEventListener('click', function() {
          if (answered) return;
          answered = true;
          const chosen = parseInt(this.dataset.index);
          const correct = questions[index].correct;
          const allOptions = document.getElementById('options-box').querySelectorAll