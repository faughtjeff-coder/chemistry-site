---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Quizzes" description="Test your chemistry knowledge with interactive quizzes">
  <style>
    h1 { font-size: 28px; font-weight: 600; color: #26215C; margin-bottom: 8px; }
    .subtitle { font-size: 16px; color: #888; margin-bottom: 2rem; }
    .coming-soon { background: #EAF3DE; border-radius: 12px; padding: 2rem; text-align: center; color: #27500A; }
  </style>
  <h1>Quizzes</h1>
  <p class="subtitle">Test your knowledge across every topic and level</p>
  <div class="coming-soon">Quizzes coming soon!</div>
</Layout>