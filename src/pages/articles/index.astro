---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Articles" description="Chemistry articles for every level">
  <style>
    h1 { font-size: 28px; font-weight: 600; color: #26215C; margin-bottom: 8px; }
    .subtitle { font-size: 16px; color: #888; margin-bottom: 2rem; }
    .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
    .card { border-radius: 12px; padding: 1.5rem; text-decoration: none; display: block; }
    .card h2 { font-size: 18px; font-weight: 600; margin-bottom: 6px; }
    .card p { font-size: 14px; line-height: 1.5; }
  </style>
  <h1>Articles</h1>
  <p class="subtitle">Pick your level or browse by topic</p>
  <div class="grid">
    <a href="/articles/reactions" class="card" style="background:#EEEDFE;color:#26215C;">
      <h2>Reactions</h2>
      <p>Dramatic visual reactions explained with real chemistry</p>
    </a>
    <a href="/articles/beginner" class="card" style="background:#FAEEDA;color:#633806;">
      <h2>Beginner</h2>
      <p>Start here — no prior knowledge needed</p>
    </a>
    <a href="/articles/general" class="card" style="background:#E1F5EE;color:#085041;">
      <h2>General Chemistry</h2>
      <p>Core high school topics explained clearly</p>
    </a>
    <a href="/articles/ap" class="card" style="background:#E6F1FB;color:#0C447C;">
      <h2>AP Chemistry</h2>
      <p>Deep dives for AP exam prep and beyond</p>
    </a>
  </div>
</Layout>