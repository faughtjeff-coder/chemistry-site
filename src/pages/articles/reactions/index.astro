---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="Reactions" description="Explore dramatic chemistry reactions explained at high school level">
  <style>
    h1 { font-size: 28px; font-weight: 600; color: #26215C; margin-bottom: 8px; }
    .subtitle { font-size: 16px; color: #888; margin-bottom: 2rem; }
    .coming-soon { background: #EEEDFE; border-radius: 12px; padding: 2rem; text-align: center; color: #534AB7; }
  </style>
  <h1>Reactions</h1>
  <p class="subtitle">Dramatic, visual, curriculum-linked reaction articles</p>
  <div class="coming-soon">More reactions coming every week. Check back soon!</div>
</Layout>