---
import Layout from '../layouts/Layout.astro';

const allReactions = import.meta.glob('./reactions/**/index.astro');
const reactionSlugs = Object.keys(allReactions)
  .map(path => path.replace('./reactions/', '').replace('/index.astro', ''))
  .filter(slug => slug !== '' && !slug.includes('/'))
  .sort()
  .reverse();

const featuredSlug = reactionSlugs[0] || 'elephant-toothpaste';
const featuredTitle = featuredSlug.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
---
<Layout title="Home" description="ChemSpark — chemistry articles, tools and quizzes for every level">
  <style>
    .featured-banner {
      background: #3C3489;
      border-radius: 12px;
      padding: 2rem;
      margin-bottom: 2rem;
      position: relative;
      overflow: hidden;
    }
    .featured-tag {
      background: #FAC775;
      color: #412402;
      font-size: 11px;
      font-weight: 600;
      padding: 4px 12px;
      border-radius: 999px;
      display: inline-block;
      margin-bottom: 12px;
    }
    .featured-title {
      font-size: 26px;
      font-weight: 600;
      color: #EEEDFE;
      line-height: 1.3;
      margin-bottom: 10px;
      max-width: 520px;
      text-transform: capitalize;
    }
    .featured-desc {
      font-size: 15px;
      color: #AFA9EC;
      line-height: 1.6;
      max-width: 500px;
      margin-bottom: 16px;
    }
    .featured-btn {
      background: #534AB7;
      color: #EEEDFE;
      font-size: 14px;
      font-weight: 500;
      padding: 10px 20px;
      border-radius: 999px;
      text-decoration: none;
      display: inline-block;
    }
    .featured-btn:hover { background: #7F77DD; }
    .section-label {
      font-size: 11px;
      font-weight: 600;
      color: #888;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 12px;
    }
    .topic-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 2rem;
    }
    .pill {
      font-size: 13px;
      padding: 7px 16px;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 500;
    }
    .cards {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
      margin-bottom: 2rem;
    }
    .card {
      background: white;
      border-radius: 12px;
      border: 0.5px solid #e0e0e0;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
    }
    .card:hover { border-color: #AFA9EC; }
    .card-img {
      height: 80px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card-body { padding: 0.75rem 1rem; }
    .card-tag {
      font-size: 11px;
      padding: 2px 8px;
      border-radius: 4px;
      display: inline-block;
    }
    .card-title {
      font-size: 14px;
      font-weight: 500;
      margin-top: 6px;
      color: #1a1a2e;
    }
    .card-topic {
      font-size: 12px;
      color: #888;
      margin-top: 2px;
    }
  </style>

  <div class="featured-banner">
    <span class="featured-tag">Reaction of the week</span>
    <h1 class="featured-title">{featuredTitle}</h1>
    <p class="featured-desc">Explore one of chemistry's most dramatic reactions — explained clearly with videos, equations and real research links.</p>
    <a href={`/reactions/${featuredSlug}`} class="featured-btn">Read now →</a>
  </div>

  <div class="section-label">Browse by topic</div>
  <div class="topic-pills">
    <a href="/topics/atomic-structure" class="pill" style="background:#26215C;color:#CECBF6;">Atomic Structure</a>
    <a href="/topics/bonding" class="pill" style="background:#085041;color:#9FE1CB;">Bonding</a>
    <a href="/topics/reactions" class="pill" style="background:#633806;color:#FAC775;">Reactions</a>
    <a href="/topics/acids-and-bases" class="pill" style="background:#712B13;color:#F5C4B3;">Acids & Bases</a>
    <a href="/topics/thermodynamics" class="pill" style="background:#0C447C;color:#B5D4F4;">Thermodynamics</a>
    <a href="/topics/organic-chemistry" class="pill" style="background:#72243E;color:#F4C0D1;">Organic Chemistry</a>
    <a href="/topics/periodic-table" class="pill" style="background:#27500A;color:#C0DD97;">Periodic Table</a>
    <a href="/topics/electrochemistry" class="pill" style="background:#3C3489;color:#AFA9EC;">Electrochemistry</a>
  </div>

  <div class="section-label">Recent articles</div>
  <div class="cards">
    <a href="/topics/atomic-structure/what-is-an-atom" class="card">
      <div class="card-img" style="background:#085041;">
        <svg width="60" height="60" viewBox="0 0 60 60">
          <circle cx="30" cy="30" r="12" fill="#9FE1CB"/>
          <circle cx="30" cy="30" r="5" fill="#085041"/>
          <circle cx="50" cy="30" r="5" fill="#5DCAA5"/>
          <circle cx="10" cy="30" r="5" fill="#5DCAA5"/>
          <circle cx="40" cy="13" r="5" fill="#5DCAA5"/>
          <circle cx="20" cy="47" r="5" fill="#5DCAA5"/>
          <line x1="30" y1="30" x2="50" y2="30" stroke="#9FE1CB" stroke-width="1.5"/>
          <line x1="30" y1="30" x2="10" y2="30" stroke="#9FE1CB" stroke-width="1.5"/>
          <line x1="30" y1="30" x2="40" y2="13" stroke="#9FE1CB" stroke-width="1.5"/>
          <line x1="30" y1="30" x2="20" y2="47" stroke="#9FE1CB" stroke-width="1.5"/>
        </svg>
      </div>
      <div class="card-body">
        <span class="card-tag" style="background:#FAEEDA;color:#633806;">Beginner</span>
        <div class="card-title">What is an atom?</div>
        <div class="card-topic">Atomic structure</div>
      </div>
    </a>
    <a href="/topics/bonding/ionic-bonds-explained" class="card">
      <div class="card-img" style="background:#085041;">
        <svg width="60" height="60" viewBox="0 0 60 60">
          <circle cx="20" cy="30" r="12" fill="#9FE1CB"/>
          <circle cx="40" cy="30" r="12" fill="#5DCAA5"/>
          <text x="20" y="34" text-anchor="middle" font-size="10" fill="#085041" font-weight="bold">Na⁺</text>
          <text x="40" y="34" text-anchor="middle" font-size="10" fill="#085041" font-weight="bold">Cl⁻</text>
        </svg>
      </div>
      <div class="card-body">
        <span class="card-tag" style="background:#EEEDFE;color:#534AB7;">General</span>
        <div class="card-title">Ionic bonds explained</div>
        <div class="card-topic">Bonding</div>
      </div>
    </a>
    <a href="/topics/reactions/types-of-chemical-reactions" class="card">
      <div class="card-img" style="background:#633806;">
        <svg width="70" height="50" viewBox="0 0 70 50">
          <rect x="5" y="15" width="12" height="22" rx="3" fill="#FAC775"/>
          <text x="11" y="30" text-anchor="middle" font-size="9" fill="#412402" font-weight="500">H₂</text>
          <text x="32" y="28" text-anchor="middle" font-size="14" fill="#EF9F27">+</text>
          <rect x="43" y="15" width="12" height="22" rx="3" fill="#FAC775"/>
          <text x="49" y="30" text-anchor="middle" font-size="9" fill="#412402" font-weight="500">O₂</text>
          <text x="61" y="28" text-anchor="middle" font-size="14" fill="#EF9F27">→</text>
        </svg>
      </div>
      <div class="card-body">
        <span class="card-tag" style="background:#FAEEDA;color:#633806;">General</span>
        <div class="card-title">Types of reactions</div>
        <div class="card-topic">Reactions</div>
      </div>
    </a>
  </div>
</Layout>
