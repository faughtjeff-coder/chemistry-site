---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Home" description="ChemSpark — chemistry articles, tools and quizzes for every level">
  <style>
    .featured-banner {
      background: #3C3489;
      border-radius: 12px;
      padding: 2rem;
      margin-bottom: 2rem;
      position: relative;
      overflow: hidden;
    }
    .featured-tag {
      background: #FAC775;
      color: #412402;
      font-size: 11px;
      font-weight: 600;
      padding: 4px 12px;
      border-radius: 999px;
      display: inline-block;
      margin-bottom: 12px;
    }
    .featured-title {
      font-size: 26px;
      font-weight: 600;
      color: #EEEDFE;
      line-height: 1.3;
      margin-bottom: 10px;
      max-width: 520px;
    }
    .featured-desc {
      font-size: 15px;
      color: #AFA9EC;
      line-height: 1.6;
      max-width: 500px;
      margin-bottom: 16px;
    }
    .featured-btn {
      background: #534AB7;
      color: #EEEDFE;
      font-size: 14px;
      font-weight: 500;
      padding: 10px 20px;
      border-radius: 999px;
      text-decoration: none;
      display: inline-block;
    }
    .featured-btn:hover { background: #7F77DD; }
    .section-label {
      font-size: 11px;
      font-weight: 600;
      color: #888;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 12px;
    }
    .topic-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 2rem;
    }
    .pill {
      font-size: 13px;
      padding: 7px 16px;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 500;
    }
    .cards {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
      margin-bottom: 2rem;
    }
    .card {
      background: white;
      border-radius: 12px;
      border: 0.5px solid #e0e0e0;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
    }
    .card:hover { border-color: #AFA9EC; }
    .card-img {
      height: 80px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card-body { padding: 0.75rem 1rem; }
    .card-tag {
      font-size: 11px;
      padding: 2px 8px;
      border-radius: 4px;
      display: inline-block;
    }
    .card-title {
      font-size: 14px;
      font-weight: 500;
      margin-top: 6px;
      color: #1a1a2e;
    }
    .card-topic {
      font-size: 12px;
      color: #888;
      margin-top: 2px;
    }
  </style>

  <div class="featured-banner">
    <span class="featured-tag">Reaction of the week</span>
    <h1 class="featured-title">Elephant toothpaste: when hydrogen peroxide goes wild</h1>
    <p class="featured-desc">A tiny drop of catalyst turns hydrogen peroxide into a tower of foam in seconds. Here's the dramatic chemistry behind one of the most visual reactions you can do in a classroom.</p>
    <a href="/reactions/elephant-toothpaste" class="featured-btn">Read now →</a>
  </div>

  <div class="section-label">Browse by topic</div>
  <div class="topic-pills">
    <a href="/articles/reactions" class="pill" style="background:#26215C;color:#CECBF6;">Reactions</a>
    <a href="/articles/beginner" class="pill" style="background:#085041;color:#9FE1CB;">Beginner</a>
    <a href="/articles/general" class="pill" style="background:#633806;color:#FAC775;">General Chemistry</a>
    <a href="/articles/ap" class="pill" style="background:#0C447C;color:#B5D4F4;">AP Chemistry</a>
    <a href="/articles" class="pill" style="background:#3C3489;color:#AFA9EC;">Atomic Structure</a>
    <a href="/articles" class="pill" style="background:#712B13;color:#F5C4B3;">Acids & Bases</a>
    <a href="/articles" class="pill" style="background:#27500A;color:#C0DD97;">Periodic Table</a>
    <a href="/articles" class="pill" style="background:#72243E;color:#F4C0D1;">Organic Chemistry</a>
  </div>

  <div class="section-label">Recent articles</div>
  <div class="cards">
    <a href="/articles/reactions" class="card">
      <div class="card-img" style="background:#085041;">
        <svg width="60" height="60" viewBox="0 0 60 60">
          <circle cx="30" cy="30" r="12" fill="#9FE1CB"/>
          <circle cx="30" cy="30" r="5" fill="#085041"/>
          <circle cx="50" cy="30" r="5" fill="#5DCAA5"/>
          <circle cx="10" cy="30" r="5" fill="#5DCAA5"/>
          <circle cx="40" cy="13" r="5" fill="#5DCAA5"/>
          <circle cx="20" cy="47" r="5" fill="#5DCAA5"/>
          <line x1="30" y1="30" x2="50" y2="30" stroke="#9FE1CB" stroke-width="1.5"/>
          <line x1="30" y1="30" x2="10" y2="30" stroke="#9FE1CB" stroke-width="1.5"/>
          <line x1="30" y1="30" x2="40" y2="13" stroke="#9FE1CB" stroke-width="1.5"/>
          <line x1="30" y1="30" x2="20" y2="47" stroke="#9FE1CB" stroke-width="1.5"/>
        </svg>
      </div>
      <div class="card-body">
        <span class="card-tag" style="background:#FAEEDA;color:#633806;">Beginner</span>
        <div class="card-title">What is an atom?</div>
        <div class="card-topic">Atomic structure</div>
      </div>
    </a>
    <a href="/articles/general" class="card">
      <div class="card-img" style="background:#633806;">
        <svg width="70" height="50" viewBox="0 0 70 50">
          <rect x="5" y="15" width="12" height="22" rx="3" fill="#FAC775"/>
          <text x="11" y="30" text-anchor="middle" font-size="9" fill="#412402" font-weight="500">H₂</text>
          <text x="32" y="28" text-anchor="middle" font-size="14" fill="#EF9F27">+</text>
          <rect x="43" y="15" width="12" height="22" rx="3" fill="#FAC775"/>
          <text x="49" y="30" text-anchor="middle" font-size="9" fill="#412402" font-weight="500">O₂</text>
          <text x="61" y="28" text-anchor="middle" font-size="14" fill="#EF9F27">→</text>
        </svg>
      </div>
      <div class="card-body">
        <span class="card-tag" style="background:#EEEDFE;color:#534AB7;">General</span>
        <div class="card-title">Balancing equations</div>
        <div class="card-topic">Reactions</div>
      </div>
    </a>
    <a href="/articles/ap" class="card">
      <div class="card-img" style="background:#3C3489;">
        <svg width="70" height="50" viewBox="0 0 70 50">
          <path d="M10 40 Q20 10 35 25 Q50 40 60 10" fill="none" stroke="#AFA9EC" stroke-width="2"/>
          <circle cx="35" cy="25" r="4" fill="#FAC775"/>
          <line x1="35" y1="25" x2="35" y2="8" stroke="#FAC775" stroke-width="1" stroke-dasharray="2"/>
          <text x="37" y="12" font-size="7" fill="#FAC775">Ea</text>
        </svg>
      </div>
      <div class="card-body">
        <span class="card-tag" style="background:#E1F5EE;color:#0F6E56;">AP</span>
        <div class="card-title">Le Chatelier's principle</div>
        <div class="card-topic">Equilibrium</div>
      </div>
    </a>
  </div>
</Layout>