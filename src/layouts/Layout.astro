---
const { title = "ChemSpark", description = "Chemistry for every level" } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | ChemSpark</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: system-ui, sans-serif; background: #f5f5f5; color: #1a1a2e; }
      nav { background: #26215C; padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between; position: relative; z-index: 100; }
      .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
      .logo-text { font-size: 22px; font-weight: 600; color: #FAC775; }
      .nav-links { display: flex; gap: 2rem; align-items: center; }
      .nav-links a { color: #AFA9EC; text-decoration: none; font-size: 15px; }
      .nav-links a:hover { color: #FAC775; }
      .dropdown { position: relative; }
      .dropdown-btn { color: #AFA9EC; font-size: 15px; cursor: pointer; background: none; border: none; font-family: inherit; padding: 0; }
      .dropdown-btn:hover { color: #FAC775; }
      .dropdown-menu {
        display: none;
        position: absolute;
        top: calc(100% + 12px);
        left: 0;
        background: #3C3489;
        border-radius: 8px;
        padding: 0.5rem 0;
        min-width: 200px;
        z-index: 200;
        box-shadow: 0 4px 20px rgba(0,0,0,0.3);
      }
      .dropdown-menu a {
        display: block;
        padding: 10px 18px;
        color: #AFA9EC;
        text-decoration: none;
        font-size: 14px;
        white-space: nowrap;
      }
      .dropdown-menu a:hover { background: #534AB7; color: #FAC775; }
      .dropdown.open .dropdown-menu { display: block; }
      footer { background: #26215C; padding: 1.5rem 2rem; display: flex; justify-content: space-between; align-items: center; margin-top: 3rem; }
      .footer-text { color: #7F77DD; font-size: 13px; }
      .footer-links { display: flex; gap: 1.5rem; }
      .footer-links a { color: #534AB7; text-decoration: none; font-size: 13px; }
      .footer-links a:hover { color: #AFA9EC; }
      main { max-width: 900px; margin: 0 auto; padding: 2rem 1rem; }
    </style>
  </head>
  <body>
    <nav>
      <a href="/" class="logo">
        <svg width="28" height="28" viewBox="0 0 32 32">
          <circle cx="16" cy="16" r="6" fill="#FAC775"/>
          <ellipse cx="16" cy="16" rx="14" ry="5" fill="none" stroke="#AFA9EC" stroke-width="2"/>
          <ellipse cx="16" cy="16" rx="14" ry="5" fill="none" stroke="#5DCAA5" stroke-width="2" transform="rotate(60 16 16)"/>
          <ellipse cx="16" cy="16" rx="14" ry="5" fill="none" stroke="#F09995" stroke-width="2" transform="rotate(120 16 16)"/>
        </svg>
        <span class="logo-text">ChemSpark</span>
      </a>
      <div class="nav-links">
        <div class="dropdown" id="topics-dropdown">
          <button class="dropdown-btn">Topics ▾</button>
          <div class="dropdown-menu">
            <a href="/topics/atomic-structure">Atomic Structure</a>
            <a href="/topics/bonding">Bonding</a>
            <a href="/topics/reactions">Reactions</a>
            <a href="/topics/acids-and-bases">Acids & Bases</a>
            <a href="/topics/thermodynamics">Thermodynamics</a>
            <a href="/topics/organic-chemistry">Organic Chemistry</a>
            <a href="/topics/periodic-table">Periodic Table</a>
            <a href="/topics/electrochemistry">Electrochemistry</a>
          </div>
        </div>
        <a href="/reactions">Reactions</a>
        <a href="/tools">Tools</a>
        <a href="/quizzes">Quizzes</a>
        <a href="/about">About</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <span class="footer-text">ChemSpark — chemistry for every level</span>
      <div class="footer-links">
        <a href="/reactions">Reactions</a>
        <a href="/tools">Tools</a>
        <a href="/quizzes">Quizzes</a>
        <a href="/about">About</a>
      </div>
    </footer>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const dropdown = document.getElementById('topics-dropdown');
        const btn = dropdown.querySelector('.dropdown-btn');
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          dropdown.classList.toggle('open');
        });
        document.addEventListener('click', function(e) {
          if (!dropdown.contains(e.target)) {
            dropdown.classList.remove('open');
          }
        });
      });
    </script>
  </body>
</html>